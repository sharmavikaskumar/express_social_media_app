<!DOCTYPE html>
<html lang="en">
   <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <title>Feeds</title>
      <script src="https://cdn.tailwindcss.com"></script>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
      <script>
         tailwind.config = {
           theme: {
             extend: {
               fontFamily: {
                 display: ['Playfair Display', 'serif'],
                 body: ['DM Sans', 'sans-serif'],
               },
               colors: {
                 ink: '#0f0f0f',
                 muted: '#6b6b6b',
                 bone: '#f5f2ee',
                 accent: '#c8502a',
               }
             }
           }
         }
      </script>
   </head>
   <body class="bg-gray-100 font-mono">
      <div>
         <nav class="bg-white shadow-md px-8 py-3 flex items-center justify-between">
            <div class="flex items-center gsp-3">
               <h1 class="text-xl font-bold text-black">DoMore</h1>
            </div>
            <div class="w-1/3">
               <input type="text" placeholder="Search"
                  class="w-full px-4 py-2 rounded-full bg-gray-100 outline-none">
            </div>
            <div class="flex items-center gap-6">
               <div class="bg-gray-100 px-4 px-2 rounded-xl">
                  <a href="/feed" class="text-blue-600 font-semibold">
                  Home
                  </a>
               </div>
               <i class="fa-regular fa-message text-gray-600 text-lg cursor-pointer"></i>
               <i class="fa-regular fa-bell text-gray-600 text-lg cursor-pointer"></i>
               <!-- Profile -->
               <div class="flex items-center gap-2">
                  <img 
                     src="https://i.pravatar.cc/40"
                     class="w-8 h-8 rounded-full"
                     >
                  <span class="text-sm font-medium">
                  <%= user ? user.username : "User" %>
                  </span>
               </div>
            </div>
         </nav>
         <div class="max-w-7xl mx-auto mt-6 grid grid-cols-12 gap-6 px-6">
            <!-- LEFT SIDEBAR -->
            <div class="col-span-3">
               <div class="bg-white rounded-xl shadow p-5">
                  <div class="flex flex-col items-center">
                     <img 
                        src="https://i.pravatar.cc/100"
                        class="w-20 h-20 rounded-full mb-3"
                        />
                     <h2 class="font-bold text-lg">
                        <%= user.username %>
                     </h2>
                     <p class="text-gray-500 text-sm">
                        @<%= user.username %>
                     </p>
                  </div>
                  <div class="flex justify-between mt-6 text-center">
                     <div>
                        <p class="font-bold">250</p>
                        <p class="text-gray-500 text-sm">Posts</p>
                     </div>
                     <div>
                        <p class="font-bold">2022</p>
                        <p class="text-gray-500 text-sm">Followers</p>
                     </div>
                     <div>
                        <p class="font-bold">590</p>
                        <p class="text-gray-500 text-sm">Following</p>
                     </div>
                  </div>
                  <a href="/profile"
                     class="block mt-6 text-center bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600">
                  My Profile
                  </a>
               </div>
            </div>
            <!-- FEED SECTION -->
            <!-- FEED SECTION -->
            <div class="col-span-6">
               <!-- CREATE POST -->
               <div class="bg-white p-4 rounded-xl shadow">
                  <div class="flex gap-3">
                     <img src="https://i.pravatar.cc/40"
                        class="w-10 h-10 rounded-full"/>
                     <form action="/post/create" method="POST" class="w-full">
                        <input
                           type="text"
                           name="content"
                           placeholder="Share something..."
                           class="w-full bg-gray-100 rounded-full px-4 py-2 outline-none"/>
                     </form>
                  </div>
               </div>
               <!-- POSTS FEED -->
               <div class="mt-6 space-y-6  h-[80vh] overflow-y-auto pr-2" >
                  <% posts.forEach(post => { %>
                  <div class="bg-white rounded-xl shadow p-5">
                     <!-- POST HEADER -->
                     <div class="flex items-center gap-3 mb-3">
                        <img src="https://i.pravatar.cc/40"
                           class="w-10 h-10 rounded-full"/>
                        <h3 class="font-semibold">
                           <%= post.user.username %>
                        </h3>
                     </div>
                     <!-- POST CONTENT -->
                     <p class="text-gray-700 mb-4">
                        <%= post.content %>
                     </p>
                     <!-- POST ACTIONS -->
                     <div class="flex gap-6 text-gray-500 text-sm border-t pt-3">
                        <a href="/likes/<%= post._id %>" class="hover:text-red-500 flex items-center gap-1">
                        <i class="fa-regular fa-heart"></i>
                        <%= post.likes.length %>
                        </a>
                        <span class="hover:text-blue-500 flex items-center gap-1 cursor-pointer">
                        <i class="fa-regular fa-comment"></i>
                        Comment
                        </span>
                        <span class="hover:text-green-500 flex items-center gap-1 cursor-pointer">
                        <i class="fa-solid fa-share"></i>
                        Share
                        </span>
                     </div>
                  </div>
                  <% }) %>
               </div>
            </div>
            <!-- RIGHT PANEL (EMPTY FOR NOW) -->
            <div class="col-span-3">
               <div class="col-span-3 space-y-6">
                  <!-- TRENDING -->
                  <div class="bg-white p-5 rounded-xl shadow">
                     <h3 class="font-bold text-lg mb-4">Trending</h3>
                     <ul class="space-y-3 text-sm">
                        <li class="hover:text-blue-500 cursor-pointer">
                           #WebDevelopment
                        </li>
                        <li class="hover:text-blue-500 cursor-pointer">
                           #JavaScript
                        </li>
                        <li class="hover:text-blue-500 cursor-pointer">
                           #NodeJS
                        </li>
                        <li class="hover:text-blue-500 cursor-pointer">
                           #TailwindCSS
                        </li>
                     </ul>
                  </div>
                  <!-- SUGGESTED USERS -->
                  <div class="bg-white p-5 rounded-xl shadow">
                     <h3 class="font-bold text-lg mb-4">Suggestions</h3>
                     <div class="space-y-4">
                        <!-- User -->
                        <div class="flex items-center justify-between">
                           <div class="flex items-center gap-3">
                              <img src="https://i.pravatar.cc/40?img=5"
                                 class="w-8 h-8 rounded-full">
                              <span class="text-sm font-medium">Alex</span>
                           </div>
                           <button class="text-blue-500 text-sm">
                           Follow
                           </button>
                        </div>
                        <!-- User -->
                        <div class="flex items-center justify-between">
                           <div class="flex items-center gap-3">
                              <img src="https://i.pravatar.cc/40?img=6"
                                 class="w-8 h-8 rounded-full">
                              <span class="text-sm font-medium">Sara</span>
                           </div>
                           <button class="text-blue-500 text-sm">
                           Follow
                           </button>
                        </div>
                        <!-- User -->
                        <div class="flex items-center justify-between">
                           <div class="flex items-center gap-3">
                              <img src="https://i.pravatar.cc/40?img=7"
                                 class="w-8 h-8 rounded-full">
                              <span class="text-sm font-medium">John</span>
                           </div>
                           <button class="text-blue-500 text-sm">
                           Follow
                           </button>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </div>
   </body>
</html>